rules_version = '2';

// ==============================================
// ATURAN KEAMANAN FIRESTORE
// ==============================================
// Copy-paste rules ini di Firebase Console:
// Firestore Database > Rules
// ==============================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Untuk tahap awal / development: izinkan semua akses
    // PENTING: Ganti dengan aturan yang lebih ketat sebelum production!
    match /{document=**} {
      allow read, write: if true;
    }

    // ---- ATURAN PRODUCTION (aktifkan nanti) ----
    // Uncomment rules di bawah dan hapus rule "allow all" di atas
    //
    // match /users/{userId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }
    //
    // match /members/{memberId} {
    //   allow read: if true;
    //   allow write: if true;
    // }
    //
    // match /savings/{savingId} {
    //   allow read: if true;
    //   allow write: if true;
    // }
    //
    // match /loans/{loanId} {
    //   allow read: if true;
    //   allow write: if true;
    // }
    //
    // match /settings/{settingId} {
    //   allow read: if true;
    //   allow write: if true;
    // }
  }
}
